rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow read access to all files
    match /{allPaths=**} {
      allow read;
    }
    
    // Allow authenticated users to upload their own profile pictures
    match /users/{userId}/profile.jpg {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to upload their own documents
    match /users/{userId}/documents/{document} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow users with programs permission to upload program thumbnails and files
    match /programs/{fileName} {
      allow write: if request.auth != null && 
                   (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                    firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.permissions.programs == true);
    }
    
    // Allow users with programs permission to upload program brochures (nested structure)
    match /programs/{programId}/{fileName} {
      allow write: if request.auth != null && 
                   (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                    firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.permissions.programs == true);
    }
    
    // Allow users with programs permission to upload brochures
    match /brochures/{fileName} {
      allow write: if request.auth != null && 
                   (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                    firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.permissions.programs == true);
    }
    
    // Allow users with programs permission to upload thumbnails
    match /thumbnails/{fileName} {
      allow write: if request.auth != null && 
                   (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                    firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.permissions.programs == true);
    }
    
    // Allow users with programs permission to upload program thumbnails (legacy path)
    match /program_thumbnails/{fileName} {
      allow write: if request.auth != null && 
                   (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                    firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.permissions.programs == true);
    }
    
    // Allow admins to upload blog cover images
    match /blog_covers/{fileName} {
      allow write: if request.auth != null && 
                   firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Allow admins to upload course materials
    match /courses/{courseId}/{allPaths=**} {
      allow write: if request.auth != null && 
                   firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Deny all other write requests
    match /{allPaths=**} {
      allow write: if false;
    }
  }
} 