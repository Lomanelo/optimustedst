rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // TEMPORARY DEBUG RULE - remove after testing
    match /programs/{programId} {
      allow read: if true;
      allow write: if request.auth != null; // Allow any authenticated user
    }
    
    // Helper function to check if the user is an admin - more lenient with whitespace and case
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != null && 
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.trim().toLowerCase() == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin\n'
        );
    }
    
    // Blog posts collection rules
    match /blogPosts/{postId} {
      // Allow public read access to all blog posts
      allow read: if true;
      // Allow admins to create, update, and delete blog posts
      allow create, update, delete: if isAdmin();
      // Allow admins to list all blog posts (for admin dashboard)
      allow list: if isAdmin();
    }
    
    // Allow authenticated users to read their own profile
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow admins to read and update all user profiles
    match /users/{userId} {
      allow read: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Courses collection - allow reading for all authenticated users
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Enrollments collection - users can manage their own enrollments
    match /enrollments/{enrollmentId} {
      allow read: if request.auth != null && 
                  resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && 
                    request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
                           resource.data.userId == request.auth.uid;
      // Admins can manage all enrollments
      allow read, write: if isAdmin();
    }
    
    // Website Settings collection - allow reading for all users, writing for admins only
    match /websiteSettings/{settingId} {
      allow read: if true; // Allow all users to read website settings (for social media links, etc.)
      allow write: if isAdmin(); // Only admins can modify website settings
    }
    
    // CMS Content collection - allow reading for all users, writing for admins only
    match /cms_content/{contentId} {
      allow read: if true; // Allow all users to read CMS content (needed for website display)
      allow create, update, delete: if isAdmin(); // Only admins can modify CMS content
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
} 