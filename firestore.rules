rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Programs collection - allow reading for all users, writing for users with programs permission
    match /programs/{programId} {
      allow read: if true;
      allow write: if hasPermission('programs'); // Users with programs permission can modify programs
    }
    
    // Helper function to check if the user is an admin - more lenient with whitespace and case
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != null && 
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.trim().toLowerCase() == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin\n'
        );
    }

    // Helper function to check if user has specific permission
    function hasPermission(permission) {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (
          // Check if user has admin role (bypass permission check)
          isAdmin() ||
          // Check if user has the specific permission
          (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions != null &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions[permission] == true
          )
        );
    }
    
    // Blog posts collection rules
    match /blogPosts/{postId} {
      // Allow public read access to all blog posts
      allow read: if true;
      // Allow users with 'blog' permission to create, update, and delete blog posts
      allow create, update, delete: if hasPermission('blog');
      // Allow users with 'blog' permission to list all blog posts (for admin dashboard)
      allow list: if hasPermission('blog');
    }
    
    // Allow authenticated users to read their own profile
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow users with 'users' permission to read user profiles, but only admins can modify
    match /users/{userId} {
      allow read: if hasPermission('users');
      // Only admins can modify user data (roles, permissions, status)
      allow update: if isAdmin();
      // Only admins can delete users
      allow delete: if isAdmin();
      // Allow listing users for admin interface
      allow list: if hasPermission('users');
    }
    
    // Courses collection - allow reading for all authenticated users
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if hasPermission('programs');
    }
    
    // Enrollments collection - users can manage their own enrollments
    match /enrollments/{enrollmentId} {
      allow read: if request.auth != null && 
                  resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && 
                    request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
                           resource.data.userId == request.auth.uid;
      // Users with dashboard permission can manage all enrollments
      allow read, write: if hasPermission('dashboard');
    }
    
    // Website Settings collection - allow reading for all users, writing for users with settings permission
    match /websiteSettings/{settingId} {
      allow read: if true; // Allow all users to read website settings (for social media links, etc.)
      allow write: if hasPermission('settings'); // Users with settings permission can modify website settings
    }

    // Settings collection - allow reading for all users, writing for users with settings permission
    match /settings/{settingId} {
      allow read: if true; // Allow all users to read settings (including contactInfo)
      allow write: if hasPermission('settings'); // Users with settings permission can modify settings
    }
    
    // CMS Content collection - allow reading for all users, writing for users with cms permission
    match /cms_content/{contentId} {
      allow read: if true; // Allow all users to read CMS content (needed for website display)
      allow create, update, delete: if hasPermission('cms'); // Users with cms permission can modify CMS content
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
} 