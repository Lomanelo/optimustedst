rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Programs collection - allow reading for all users, writing for users with programs permission
    match /programs/{programId} {
      allow read: if true;
      allow write: if hasPermission('programs'); // Users with programs permission can modify programs
    }
    
    // Helper function to check if the user is an admin - more lenient with whitespace and case
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != null && 
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.trim().toLowerCase() == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin\n'
        );
    }

    // Helper function to check if user has specific permission
    function hasPermission(permission) {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (
          // Check if user has admin role (bypass permission check)
          isAdmin() ||
          // Check if user has the specific permission
          (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions != null &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions[permission] == true
          )
        );
    }
    
    // Blog posts collection rules
    match /blogPosts/{postId} {
      // Allow public read access to all blog posts
      allow read: if true;
      // Allow users with 'blog' permission to create, update, and delete blog posts
      allow create, update, delete: if hasPermission('blog');
      // Allow users with 'blog' permission to list all blog posts (for admin dashboard)
      allow list: if hasPermission('blog');
    }
    
    // Users collection rules
    match /users/{userId} {
      // Users can read their own profile, or admins can read any profile, or users with 'users' permission
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin() || hasPermission('users');
      
      // Users can create their own profile, or admins can create any profile
      allow create: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      
      // Users can update their own profile, or admins can update any profile
      allow update: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      
      // Only users can delete their own profile, or admins can delete any profile
      allow delete: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      
      // Allow listing users for admin interface (admins or users with 'users' permission)
      allow list: if isAdmin() || hasPermission('users');
    }
    
    // Courses collection - allow reading for all authenticated users
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if hasPermission('programs');
    }
    
    // Enrollments collection - users can manage their own enrollments
    match /enrollments/{enrollmentId} {
      allow read: if request.auth != null && 
                  resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && 
                    request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
                           resource.data.userId == request.auth.uid;
      // Users with dashboard permission can manage all enrollments
      allow read, write: if hasPermission('dashboard');
    }
    
    // Website Settings collection - allow reading for all users, writing for users with settings permission
    match /websiteSettings/{settingId} {
      allow read: if true; // Allow all users to read website settings (for social media links, etc.)
      allow write: if hasPermission('settings'); // Users with settings permission can modify website settings
    }

    // Settings collection - allow reading for all users, writing for users with settings permission
    match /settings/{settingId} {
      allow read: if true; // Allow all users to read settings (including contactInfo)
      allow write: if hasPermission('settings'); // Users with settings permission can modify settings
    }
    
    // CMS Content collection - allow reading for all users, system auto-population, admin management
    match /cms_content/{contentId} {
      allow read, list: if true; // Allow all users (including anonymous) to read CMS content
      
      // Allow system auto-population - no auth required for initial content creation
      // This enables the system to populate missing translations automatically
      allow create: if true;
      
      // Allow users with cms permission to update and delete CMS content (admin management)
      allow update, delete: if hasPermission('cms');
    }
    
    // Legal Documents collection - allow reading active documents for all users, writing for users with terms permission
    match /legal_documents/{documentId} {
      // Allow all users to read active (published) legal documents
      allow read: if resource.data.isActive == true;
      // Allow users with terms permission to read all documents (including drafts)
      allow read: if hasPermission('terms');
      // Allow users with terms permission to create, update, and delete legal documents
      allow create, update, delete: if hasPermission('terms');
      // Allow users with terms permission to list all legal documents (for admin dashboard)
      allow list: if hasPermission('terms');
    }
    
    // Legal Document Versions collection - only users with terms permission can access
    match /legal_document_versions/{versionId} {
      allow read, create, update, delete: if hasPermission('terms');
      allow list: if hasPermission('terms');
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
} 